# Supabase
# Project URL ONLY — do NOT append /rest/v1 (the SDK adds that automatically)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# New format: sb_publishable_... (or legacy anon JWT key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
# New format: sb_secret_... (or legacy service_role JWT key) — server-side only
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Resend
RESEND_API_KEY=re_your_resend_api_key

# Tawk.to Live Chat (find both IDs in Dashboard > Administration > Chat Widget)
NEXT_PUBLIC_TAWK_PROPERTY_ID=your_tawk_property_id
NEXT_PUBLIC_TAWK_WIDGET_ID=your_tawk_widget_id

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
